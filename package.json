{
  "name": "ttc-note-ecstore",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "dotenv -e .env.development.local -- prisma generate",
    "db:push": "dotenv -e .env.development.local -- prisma db push",
    "db:studio": "dotenv -e .env.development.local -- prisma studio",
    "purchase:list": "dotenv -e .env.development.local -- node scripts/purchases-debug.js list",
    "purchase:clear": "dotenv -e .env.development.local -- node scripts/purchases-debug.js delete-all --yes",
    "purchase:clear:user": "dotenv -e .env.development.local -- node scripts/purchases-debug.js delete-user",
    "purchase:clear:id": "dotenv -e .env.development.local -- node scripts/purchases-debug.js delete-id",
    "upload:notion": "node scripts/upload-to-notion.js",
    "diag:write": "node scripts/diagnose-write-issues.js"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@notionhq/client": "^2.2.15",
    "@prisma/adapter-neon": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "dotenv-cli": "^10.0.0",
    "microcms-js-sdk": "^3.2.0",
    "next": "^15.5.0",
    "next-auth": "^4.24.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-spinners": "^0.17.0",
    "stripe": "^18.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.0",
    "prisma": "^7.4.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
