# GitHub OAuth設定
GITHUB_ID=your_github_client_id_here
GITHUB_SECRET=your_github_client_secret_here

# NextAuth設定
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# データベース設定
POSTGRES_PRISMA_URL=your_database_url_here
POSTGRES_URL_NON_POOLING=your_database_url_here

# Stripe設定
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# microCMS設定
MICROCMS_SERVICE_DOMAIN=your_microcms_service_domain_here
MICROCMS_API_KEY=your_microcms_api_key_here

# 互換キー（どちらか一方の組み合わせでOK）
SERVICE_DOMAIN=your_microcms_service_domain_here
API_KEY=your_microcms_api_key_here
